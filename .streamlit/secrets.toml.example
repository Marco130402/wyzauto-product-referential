# Copy this file to .streamlit/secrets.toml and fill in the values.
# NEVER commit secrets.toml to Git (it's in .gitignore).
#
# The service account needs, on wyzauto-v2-prod:
#   - bigquery.jobs.create  (run queries / bill jobs)
#   - bigquery.dataViewer on base_tables  (product, product_specification,
#     attribute, product_price, category)
# The existing read-only SA (claude-bq-reader@wyzauto-v2-prod) already qualifies.

[gcp_service_account]
type = "service_account"
project_id = "wyzauto-v2-prod"
private_key_id = "YOUR_KEY_ID"
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "claude-bq-reader@wyzauto-v2-prod.iam.gserviceaccount.com"
client_id = "YOUR_CLIENT_ID"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/claude-bq-reader%40wyzauto-v2-prod.iam.gserviceaccount.com"

# Shared password. Colleagues sign in with their @wyzauto.com email + this password.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(12))"
[access]
password = "REPLACE_WITH_SHARED_PASSWORD"

# Access logging: each successful sign-in appends (timestamp, email) to this Sheet.
# Setup:
#   1. Create a Google Sheet.
#   2. Share it (Editor) with the service-account email above
#      (claude-bq-reader@wyzauto-v2-prod.iam.gserviceaccount.com).
#   3. Enable the "Google Sheets API" on project wyzauto-v2-prod.
#   4. Paste the Sheet ID (the long token in its URL, /d/<SHEET_ID>/edit) below.
# Leave blank to disable logging.
[notify]
sheet_id = ""
